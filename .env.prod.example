# Flick Migration - Production Environment
# Copy to .env.prod and fill in values
# WARNING: Use with extreme caution. The reset script will NOT run against prod.

# Firebase (prod project)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account-prod.json
FIREBASE_STORAGE_BUCKET=your-prod-project.appspot.com

# Supabase (prod project)
SUPABASE_URL=https://your-prod-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-prod-service-role-key

# Optional
EXPO_PUBLIC_SUPABASE_URL=https://your-prod-project.supabase.co
SUPABASE_ANON_KEY=your-prod-anon-key
