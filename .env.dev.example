# Flick Migration - Dev Environment
# Copy to .env.dev and fill in values

# Firebase (dev project)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account-dev.json
FIREBASE_STORAGE_BUCKET=your-dev-project.appspot.com

# Supabase (dev project)
SUPABASE_URL=https://your-dev-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-dev-service-role-key

# Optional
EXPO_PUBLIC_SUPABASE_URL=https://your-dev-project.supabase.co
SUPABASE_ANON_KEY=your-dev-anon-key
